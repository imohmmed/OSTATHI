{
  "expo": {
    "name": "استاذي",
    "slug": "ustadhi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ustadhi-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101D36"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ustadhi.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج إلى الكاميرا لبث الدروس المباشرة",
        "NSMicrophoneUsageDescription": "نحتاج إلى الميكروفون لبث الدروس المباشرة",
        "NSPhotoLibraryUsageDescription": "نحتاج إلى الصور لتحميل الصور الشخصية"
      }
    },
    "android": {
      "package": "com.ustadhi.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#101D36"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-video",
        {
          "enableNotificationControls": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {}
  }
}
